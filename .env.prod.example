# Production env for the full docker-compose.yml stack.
# Copy to `.env` next to docker-compose.yml on the host that runs it
# (build machine AND the VPS). Compose auto-loads `.env`.
#
#   cp .env.prod.example .env   &&   edit
#
# (For LOCAL DEV use .env.example → apps/web/.env.local instead; this file is
#  only for the containerized prod stack.)

# ── Mandatory secrets ─────────────────────────────────────────────────────────
# HMAC for session cookies. >=32 chars.  openssl rand -base64 48
SESSION_SECRET=
# AES-256 vault key. 32 random bytes, base64.  openssl rand -base64 32
MANTLE_MASTER_KEY=
# OPTIONAL. UUID of your single auth.users row. Leave BLANK for a fresh install
# (the runtime auto-resolves the sole user; create your account in the web app on
# first visit). Set it only when importing existing data — it must match the user
# in that data — or to disambiguate a multi-DB setup.
#   (from dev:  docker exec mantle_pg psql -U postgres -d postgres -tA -c "select id from auth.users limit 1")
ALLOWED_USER_ID=

# ── Postgres / object storage ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me
S3_ACCESS_KEY=minio
S3_SECRET_KEY=change-me-too

# ── Public origin (share links, email links, agent tools) ─────────────────────
MANTLE_PUBLIC_URL=https://mantle.example.com

# ── Caddy front door (automatic HTTPS) ────────────────────────────────────────
# The address Caddy serves. A hostname → Caddy gets a Let's Encrypt cert
# automatically (point a DNS A record at the VPS + open ports 80/443 first).
# Leave as :80 for local HTTP testing without a domain.
MANTLE_SITE_ADDRESS=mantle.example.com

# ── Persistent data location (host bind-mount root) ───────────────────────────
# postgres, minio, and files all live under here. Back it up; rsync it to move
# files between machines. (Move the DB itself via scripts/db-dump.sh, not by
# copying postgres/.)  Absolute path recommended on the VPS, e.g. /opt/mantle/data
MANTLE_DATA_DIR=./data

# ── Docker Hub image (pull, or build → push → pull) ───────────────────────
# Every service runs from ONE image: <namespace>/mantle:<tag>. The default
# (titanwest) is the official published image — most installs never change it.
# Self-builders: set your own Docker Hub user/org (scripts/docker-build-push.sh
# reads it too). Pin MANTLE_IMAGE_TAG to a release (e.g. v0.20.66) for
# reproducible updates; `latest` tracks the newest release.
MANTLE_IMAGE_NAMESPACE=titanwest
MANTLE_IMAGE_TAG=latest

# ── Local embedder (bundled Ollama) ───────────────────────────────────────────
# Defaults are fine. Set OLLAMA_KEEP_ALIVE=-1 to keep the embedder resident.
# OLLAMA_KEEP_ALIVE=5m
# MANTLE_EMBEDDING_PULL_MODEL=embeddinggemma
#
# On a small CPU-only box, large files can time out mid-embed (many chunks per
# file × slow inference). If you see extractor "operation aborted due to timeout"
# errors on big files, tune these down — serialize extraction so jobs don't
# contend for cores, and shrink each embed request so it clears the window:
# EXTRACT_CONCURRENCY=1
# MANTLE_LOCAL_EMBED_BATCH=8
# MANTLE_LOCAL_EMBED_TIMEOUT_MS=120000   # raise (ms) for very slow hardware
# MANTLE_EXTRACT_EXPIRE_MIN=60           # max minutes a single extraction may run
#                                        # before pg-boss expires+retries the job.
#                                        # Default 60; raise if big docs still
#                                        # dead-letter mid-embed on very slow CPUs.
# The real fix for bulky-document workloads is a faster embedder (more vCPU, a
# GPU, or a remote EmbeddingGemma route). Full guide: docs/embeddings.md
# ("Throughput on a CPU-only box").

# ── Tailscale (optional — `docker compose --profile tailnet up -d`) ───────────
# Reach models on a box you own behind NAT. Generate an auth key in the TS admin
# console. See docs/tailscale.md.
# TS_AUTHKEY=
# TS_HOSTNAME=mantle-vps
