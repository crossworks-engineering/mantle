# Production env for the full docker-compose.yml stack.
# Copy to `.env` next to docker-compose.yml on the host that runs it
# (build machine AND the VPS). Compose auto-loads `.env`.
#
#   cp .env.prod.example .env   &&   edit
#
# (For LOCAL DEV use .env.example → apps/web/.env.local instead; this file is
#  only for the containerized prod stack.)

# ── Mandatory secrets ─────────────────────────────────────────────────────────
# HMAC for session cookies. >=32 chars.  openssl rand -base64 48
SESSION_SECRET=
# AES-256 vault key. 32 random bytes, base64.  openssl rand -base64 32
MANTLE_MASTER_KEY=
# UUID of your single auth.users row. Must match the user in the data you import.
#   (from dev:  docker exec mantle_pg psql -U postgres -d postgres -tA -c "select id from auth.users limit 1")
ALLOWED_USER_ID=

# ── Postgres / object storage ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me
S3_ACCESS_KEY=minio
S3_SECRET_KEY=change-me-too

# ── Public origin (share links, email links, agent tools) ─────────────────────
MANTLE_PUBLIC_URL=https://mantle.example.com

# ── Persistent data location (host bind-mount root) ───────────────────────────
# postgres, minio, and files all live under here. Back it up; rsync it to move
# files between machines. (Move the DB itself via scripts/db-dump.sh, not by
# copying postgres/.)  Absolute path recommended on the VPS, e.g. /opt/mantle/data
MANTLE_DATA_DIR=./data

# ── Docker Hub images (build → push → pull) ───────────────────────────────────
# Your Docker Hub user/org and the tag to run. The build/push script and the
# VPS `docker compose pull` both read these.
MANTLE_IMAGE_NAMESPACE=youruser
MANTLE_IMAGE_TAG=latest

# ── Local embedder (bundled Ollama) ───────────────────────────────────────────
# Defaults are fine. Set OLLAMA_KEEP_ALIVE=-1 to keep the embedder resident.
# OLLAMA_KEEP_ALIVE=5m
# MANTLE_EMBEDDING_PULL_MODEL=embeddinggemma

# ── Tailscale (optional — `docker compose --profile tailnet up -d`) ───────────
# Reach models on a box you own behind NAT. Generate an auth key in the TS admin
# console. See docs/tailscale.md.
# TS_AUTHKEY=
# TS_HOSTNAME=mantle-vps
