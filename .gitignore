# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.js

# testing
coverage/

# next.js
.next/
out/

# production
build/
dist/
# …but the Apps API route segment is named `build` — it's source, not output.
# (brackets escaped: `[id]` is a literal dir, not a glob character class.)
!apps/web/app/api/apps/\[id\]/build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env files
.env*.local
.env.local.*
.env
# defensive: catch a no-leading-dot env file at the repo root
/env.local

# database snapshots — multi-GB local-only artefacts. ROOT-ANCHORED on
# purpose: the unanchored `backups/` matched at any depth and silently
# swallowed apps/web/app/(app)/settings/backups/ (the Backups settings
# page) — it never reached git or production (caught 2026-06-11).
/backups/

# MANTLE_FILES_ROOT default — the host-mirrored filesystem. Root-anchored
# like /backups/ above; apps/web/data is the dev runtime data dir and gets
# its own anchored entry.
/data/
/apps/web/data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# turbo/cache
.turbo/

# Claude Code local state (worktrees, session settings)
.claude/

# editor
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.recommended.json

# logs
logs/
*.log

# Agent skills — installed/vendored locally (re-fetchable via the skill
# manager from skills-lock.json); not needed to build or run the app.
.agents/
skills-lock.json

# Recall-eval run snapshots — regenerated per run, contain personal queries.
# The gold cases (recall-cases.json) and the runner ARE committed.
apps/web/scripts/eval/last-run.json
apps/web/scripts/eval/*.run.json
