# Mantle reverse proxy + automatic HTTPS.
#
# The site address comes from the MANTLE_SITE_ADDRESS env var (set in .env):
#   - a hostname  (e.g. mantle.example.com) → Caddy provisions + renews a
#                  Let's Encrypt certificate automatically. Point a DNS A/AAAA
#                  record at the VPS first, and open ports 80 + 443.
#   - ":80"        (the default) → plain HTTP, for local testing without a domain.
#
# Caddy reaches the app over the internal docker network at web:3000 — the web
# container no longer publishes a public port. ACME state lives in the caddy_data
# volume (persist it, or you'll hit Let's Encrypt rate limits on redeploys).
{$MANTLE_SITE_ADDRESS::80} {
	encode zstd gzip

	# Forward to the Next.js app. Caddy adds X-Forwarded-{For,Proto,Host} so the
	# app can build correct absolute URLs + set secure cookies behind TLS.
	reverse_proxy web:3000

	# Generous body limit for file/photo uploads through the proxy.
	request_body {
		max_size 100MB
	}
}

# The owner-UI (client) vhost — v0.200.0 split. Point app.<domain> DNS here and
# set MANTLE_CLIENT_SITE_ADDRESS in .env; the client stack's client-web joins
# this stack's network (see docker-compose.client.yml). Defaults to :8080 so a
# server-only box (no client stack, var unset) doesn't ACME-thrash a hostname
# it doesn't serve — the port listens, gets no traffic, and costs nothing.
{$MANTLE_CLIENT_SITE_ADDRESS::8080} {
	encode zstd gzip
	reverse_proxy client-web:3000
	request_body {
		max_size 100MB
	}
}

# NOTE: this is the generic, single-site front door shipped to every install.
# The author's prod also co-locates a "Mantle Push" relay on a second site block
# (push.crossworks.network). That stays OUT of the public Caddyfile on purpose:
# its hostname points at the author's own box, so on any other install Caddy
# would endlessly fail to obtain a cert for a domain it doesn't control —
# log spam plus a real Let's Encrypt rate-limit risk on that zone. Operators who
# run the push relay add their own site block via a private overlay Caddyfile.
