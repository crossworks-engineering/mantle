###############################################################################
# Mantle production Supabase environment.
#
# Every value here is required. Copy to `.env` next to docker-compose.yml and
# fill in. All secrets are sensitive — store the live .env in your password
# manager / secrets vault, not in git.
###############################################################################

# ── Postgres ────────────────────────────────────────────────────────────────
# Used by every Supabase service to connect, and by the Mantle app's
# DATABASE_URL. Strong, random — 24+ chars. Generate:
#   openssl rand -base64 24
POSTGRES_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────────────────────
# This is the master key Supabase Auth signs JWTs with. ANON_KEY and
# SERVICE_ROLE_KEY below are themselves JWTs signed with this. Must be
# 32+ characters. Generate:
#   openssl rand -base64 48
JWT_SECRET=

# JWT lifetime in seconds. Default 1 hour; auth.js handles refresh.
JWT_EXP=3600

# ── API keys (derived from JWT_SECRET) ──────────────────────────────────────
# These are JWTs you generate ONCE and bake in. The Supabase docs have a
# generator at https://supabase.com/docs/guides/self-hosting#api-keys, or:
#
#   ANON_KEY        = sign({"role":"anon","iss":"supabase","iat":...,"exp":...}, JWT_SECRET)
#   SERVICE_ROLE_KEY= sign({"role":"service_role","iss":"supabase","iat":...,"exp":...}, JWT_SECRET)
#
# Use a 10-year exp so you're not chasing renewal. Rotation: change
# JWT_SECRET and re-issue both keys.
ANON_KEY=
SERVICE_ROLE_KEY=

# ── URLs ────────────────────────────────────────────────────────────────────
# The three subdomains are hardcoded in Caddyfile (not env-templated) since
# they're public DNS names, not secrets:
#
#   db.crossworks.network      → Supabase API (live)
#   mantle.crossworks.network  → Next.js app  (reserved)
#   mcp.crossworks.network     → MCP server   (reserved)
#
# These two URLs do still come from env because GoTrue bakes them into
# email links and redirect URLs:

# Where the Mantle app lives. Used by GoTrue for things like the "click
# this link to confirm your email" URLs. During development this is
# localhost; switch once the app is deployed.
SITE_URL=https://mantle.crossworks.network

# Where the Supabase API is publicly reachable. Used by GoTrue when
# generating absolute URLs in its responses.
API_EXTERNAL_URL=https://db.crossworks.network

# Anything GoTrue should allow as a post-auth redirect target.
# Comma-separated; wildcard ends `/**` allowed. Includes localhost so
# OAuth callbacks during local development land where the dev server
# expects.
ADDITIONAL_REDIRECT_URLS=https://mantle.crossworks.network/**,http://localhost:3000/**

# ── Auth (GoTrue) ───────────────────────────────────────────────────────────
# Single-user Mantle: disable signup so randos can't create accounts even
# though the ALLOWED_USER_ID gate in middleware would reject them anyway.
DISABLE_SIGNUP=true

# Auto-confirm emails without sending. Required if you don't wire SMTP.
# If you DO wire SMTP, set this to false and configure the GOTRUE_SMTP_*
# vars (not enumerated here — see upstream Supabase docs).
ENABLE_EMAIL_AUTOCONFIRM=true

# Google as a Supabase Auth provider (for "Sign in with Google" on /login).
# NOTE: this is separate from Mantle's Gmail-data OAuth which has its own
# GOOGLE_CLIENT_ID/SECRET in the Mantle app .env. Leave disabled unless
# you specifically want Google as a login method here.
GOTRUE_EXTERNAL_GOOGLE_ENABLED=false
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=
GOTRUE_EXTERNAL_GOOGLE_SECRET=
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=

# ── Studio (Kong basic-auth) ────────────────────────────────────────────────
# Studio is NOT publicly exposed by Caddy — the / and /pg/* routes were
# dropped to shrink public attack surface. These credentials only matter
# if you ever bind Kong to the server's loopback (add a port mapping in
# docker-compose.yml) and SSH-tunnel to it for occasional admin. Safe to
# leave blank if you don't plan to do that — you can edit them later.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
