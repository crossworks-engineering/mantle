{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node", "react", "react-dom"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    // tsx (the runtime) applies THIS tsconfig only to files its `include`
    // matches — web-ui ships raw .tsx that the /s SSR renders, and without
    // this line those files compile with esbuild's default CLASSIC jsx
    // (`React is not defined` at render). Typecheck cost is nil: web-ui is
    // typechecked in its own package with the same base config.
    "../../packages/web-ui/src/**/*.ts",
    "../../packages/web-ui/src/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
