{
  "name": "@mantle/e2e",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "End-to-end regression net for the server/client split — runs against a live stack, parameterized same-origin vs split topology.",
  "scripts": {
    "e2e": "playwright test",
    "e2e:same": "playwright test --project=same-origin",
    "e2e:split": "playwright test --project=split",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2"
  }
}
