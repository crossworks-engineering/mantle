# Copy to .env.local at the repo root. Each app reads what it needs from process.env.

# Postgres connection (Drizzle + pg-boss use this directly).
# Lean stack: postgres in docker on 54323. Old Supabase tunnel was 54322.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54323/postgres

# --- DB-less frontend dev (optional) ------------------------------------------
# Set these to run `pnpm -C apps/web dev` against a DEPLOYED Mantle's HTTP API
# instead of a local Postgres — no DATABASE_URL / Tailscale needed. Mint the
# token against the remote: POST {email,password} to <remote>/api/auth/mobile-login.
# Inert when unset (normal in-process DB access). See docs/db-less-dev.md.
# MANTLE_REMOTE_API=https://mantle.example.com
# MANTLE_API_TOKEN=

# --- Auth ---------------------------------------------------------------------
# Used to HMAC the session cookie. >=32 chars. Generate: openssl rand -base64 48
# Rotating this invalidates every existing session.
SESSION_SECRET=

# --- Object storage (self-hosted MinIO in docker-compose.dev.yml) -------------
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=mantle

# --- Host filesystem for the /files surface -----------------------------------
# Where the files.* tree is mirrored on disk (uploads, Saskia's file_create,
# Telegram photos, generated images). MUST be an ABSOLUTE path SHARED by every
# process — web, agent, and the workers. If left unset it defaults to a
# cwd-relative ./data/files, which means each process uses a different root and
# files written by one (e.g. a web upload) are invisible to another (e.g. the
# agent's extractor). Set this.
MANTLE_FILES_ROOT=/absolute/path/to/data/files

# Documentation root: where the docs-sync worker reads markdown for the
# `documentation` node type (the /docs viewer + Docs agent). Defaults to a
# cwd-relative ./docs; set it to the repo's docs/ as an absolute path shared by
# every process. Indexing is opt-in per collection at /settings/documentation.
MANTLE_DOCS_ROOT=/absolute/path/to/mantle/docs

# --- Document parsing fallback (Apache Tika) ----------------------------------
# Mantle's in-process parsers (pdf-parse / mammoth / SheetJS) handle PDF, DOCX,
# XLSX/XLS, and plain text directly. For everything else — LibreOffice native
# (.odt/.ods/.odp), PowerPoint (.pptx/.ppt), legacy Word (.doc), RTF, EPUB —
# parseDocumentBytes falls through to Apache Tika. Tika runs as a sibling
# docker service (`mantle_tika`, see docker-compose.dev.yml) on 9998; the
# default below assumes dev (host port). In prod docker-compose, web/agent/
# workers reach Tika by service name via TIKA_URL=http://tika:9998. The Tika
# wrapper is never-throws — if the service is down or the bytes are
# unparseable, the extractor records skipped:no_text_layer (honest skip).
TIKA_URL=http://127.0.0.1:9998

# --- Mantle ---------------------------------------------------------------------
# 32 random bytes, base64-encoded. Generate: openssl rand -base64 32
MANTLE_MASTER_KEY=

# OPTIONAL. UUID of the single user in auth.users — used by the MCP server +
# workers to scope queries. Leave BLANK for a normal self-hosted setup: the
# runtime auto-resolves the sole auth.users row, so a fresh install just needs
# you to create your account in the web app (first visit → "Create your
# account"). Only set this for scripts, or to disambiguate a multi-DB setup.
#   psql $DATABASE_URL -tA -c "SELECT id FROM auth.users LIMIT 1"
ALLOWED_USER_ID=

# Base URL the Mantle Next.js app is reachable at. Used by server-side code
# that generates absolute links (worker notifications, MCP tool responses)
# where there's no incoming HTTP request to derive a host from. The agent also
# uses it to build public /s/<token> share links (page_share, email_page's
# includeLink); set MANTLE_PUBLIC_URL to override it for the agent only.
# Dev:  http://localhost:3000
# Prod: https://mantle.crossworks.network
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Embeddings (optional in v1, required for AI semantic search) --------------
OPENAI_API_KEY=

# --- MCP server ----------------------------------------------------------------
MCP_HTTP_PORT=8765

# --- Terminal tool (power-user coder agent) -----------------------------------
# Default working directory for the `run_terminal` builtin tool. Set to the
# mantle repo so git/pnpm/migrations "just work"; commands can override per call.
# In prod this runs INSIDE the agent container — host actions need a separate hatch.
MANTLE_TERMINAL_CWD=/Users/jasonschoeman/Projects/mantle
