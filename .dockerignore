# Drop everything that doesn't belong in the build context.
.git
.gitignore
.claude
.husky
.vscode
.idea
.env
.env.local
**/.env
**/.env.local
**/node_modules
**/.next
**/dist
**/.turbo
**/coverage
**/.DS_Store
**/*.log
backups
# Host bind-mount data root (postgres/minio/files) — never goes in an image.
data
# NOTE: docs/ IS baked into the image on purpose — it's the source for the
# `documentation` node type (MANTLE_DOCS_ROOT=/app/docs), reconciled into the
# brain by worker_docs. Do not re-add `docs` here.
README.md
*.dump
